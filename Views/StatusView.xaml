<Window x:Class="TestManager.Views.StatusView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TestManager.ViewModels"
        xmlns:pages="clr-namespace:TestManager.Views.Pages"
        Title="Test Manager"
        Width="900"
        Height="500"
        Background="#FFE7E9F8"
        Icon="/Views/logo mini.png">

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:InfoViewModel}">
            <pages:InfoView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ParametersViewModel}">
            <pages:ParametersView/>
        </DataTemplate>

        
        <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
            <pages:ResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestsViewModel}">
            <pages:TestsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
            <pages:ResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <pages:LogsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <pages:HistoryView/>
        </DataTemplate>
        

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <Border Background="#FFE0E3F3" Padding="10" Margin="0,56,0,0">

            <StackPanel>

                <Button Content="Info"
                        Command="{Binding ShowInfoCommand}"
                        Width="165" HorizontalAlignment="Left" Background="#FFC2C5DC" Foreground="#FF091B41" BorderBrush="#FF091B41">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="165"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Info">
                                    <Setter Property="Width" Value="185"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Parameters"
                        Margin="0,10,0,0"
                        Command="{Binding ShowParametersCommand}" HorizontalAlignment="Left" Background="#FFC2C5DC" BorderBrush="#FF091B41" Foreground="#FF091B41">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="165"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Parameters">
                                    <Setter Property="Width" Value="185"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Tests"
                        Margin="0, 10, 0, 0"
                        Command="{Binding ShowTestsCommand}" HorizontalAlignment="Left" Background="#FFC2C5DC" BorderBrush="#FF091B41" Foreground="#FF091B41">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="165"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Tests">
                                    <Setter Property="Width" Value="185"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Results"
                        Margin="0, 10, 0, 0"
                        Command="{Binding ShowResultsCommand}" HorizontalAlignment="Left" Background="#FFC2C5DC" BorderBrush="#FF091B41" Foreground="#FF091B41">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="165"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Results">
                                    <Setter Property="Width" Value="185"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Logs"
                        Margin="0, 10, 0, 0"
                        Command="{Binding ShowLogsCommand}" HorizontalAlignment="Left" Background="#FFC2C5DC" BorderBrush="#FF091B41" Foreground="#FF091B41">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="165"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Logs">
                                    <Setter Property="Width" Value="185"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="History DB"
                        Margin="0, 10, 0, 0"
                        Command="{Binding ShowHistoryCommand}" HorizontalAlignment="Left" Background="#FFC2C5DC" BorderBrush="#FF091B41" Foreground="#FF091B41">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="165"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="History">
                                    <Setter Property="Width" Value="185"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

        </Border>

        <!-- RIGHT CONTENT -->
        <Grid Grid.Column="1" Margin="20,20,20,20">

            <ContentControl Content="{Binding CurrentView}"/>

        </Grid>

        <!-- LOGO -->
        <Image HorizontalAlignment="Center"
               Height="46"
               Margin="0,10,0,0"
               VerticalAlignment="Top"
               Width="180"
               Source="/Views/tfortis.png"/>

    </Grid>
</Window>
