<UserControl x:Class="TestManager.Views.Pages.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:TestManager.Helpers">
    <!-- ДОБАВЛЕНО -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Журнал тестирования" FontSize="20" FontWeight="Bold" Foreground="#FF091B41" HorizontalAlignment="Left"/>

            <ToggleButton Content="Автопрокрутка" IsChecked="{Binding AutoScroll}" 
                          HorizontalAlignment="Right" Width="120" Height="25"
                          Background="#FFC2C5DC" BorderThickness="0" Foreground="#FF091B41"/>
        </Grid>

        <TabControl Grid.Row="1" Background="#FFF5F6FA" BorderBrush="#FF091B41" BorderThickness="1">

            <TabItem Header="SSH / Общее">
                <!-- ПРИМЕНЯЕМ Attached Property -->
                <ListBox x:Name="SshListBox" ItemsSource="{Binding SshLogs}" 
                         helpers:AutoScrollBehavior.AutoScroll="{Binding AutoScroll}" 
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14" Margin="0,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <TabItem Header="WEB">
                <!-- ПРИМЕНЯЕМ Attached Property -->
                <ListBox x:Name="WebListBox" ItemsSource="{Binding WebLogs}" 
                         helpers:AutoScrollBehavior.AutoScroll="{Binding AutoScroll}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14" Margin="0,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <TabItem Header="SNMP">
                <!-- ПРИМЕНЯЕМ Attached Property -->
                <ListBox x:Name="SnmpListBox" ItemsSource="{Binding SnmpLogs}" 
                         helpers:AutoScrollBehavior.AutoScroll="{Binding AutoScroll}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14" Margin="0,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>