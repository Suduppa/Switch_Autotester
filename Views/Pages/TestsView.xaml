<UserControl x:Class="TestManager.Views.Pages.TestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Доступные тесты:" FontSize="24" FontWeight="Bold" Foreground="#FF091B41" Margin="0,0,0,10"/>

        <Border Grid.Row="1" BorderBrush="#FF091B41" BorderThickness="1" Background="White" Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding AvailableTests}" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" 
                                      IsChecked="{Binding IsSelected}" 
                                      Foreground="#FF091B41" 
                                      FontSize="16" 
                                      Margin="0,5,0,5"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2" 
                Content="Запустить выбранные тесты" 
                Command="{Binding StartTestsCommand}" 
                Background="#FFEB075E" 
                Foreground="White" 
                FontSize="16" 
                FontWeight="Bold"
                Height="45"
                BorderThickness="0"/>
    </Grid>
</UserControl>