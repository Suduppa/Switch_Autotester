<UserControl x:Class="TestManager.Views.Pages.ParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TestManager.ViewModels">

    <UserControl.DataContext>
        <vm:ParametersViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">
            <TextBlock Text="Настройки запуска" FontSize="20" FontWeight="Bold" Foreground="#FF091B41" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <CheckBox Content="Использовать отложенный запуск" 
                          IsChecked="{Binding UseDelayedStart}" 
                          VerticalAlignment="Center" Foreground="#FF091B41"/>

                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" 
                            Visibility="{Binding UseDelayedStart, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Время (HH:mm):" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#FF091B41"/>
                    <TextBox Text="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="22" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Количество повторений теста:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#FF091B41"/>
                <TextBox Text="{Binding RunCount, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="22" VerticalContentAlignment="Center"/>
            </StackPanel>

            <Separator Margin="0,0,0,20"/>

            <TextBlock Text="Редактирование тестовых данных" FontSize="20" FontWeight="Bold" Foreground="#FF091B41" Margin="0,0,0,15"/>

            <TextBlock Text="Валидные строки (str_valid):" FontWeight="SemiBold" Foreground="#FF091B41" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ListBox Grid.Column="0" ItemsSource="{Binding ValidValues}" SelectedItem="{Binding SelectedValidValue}" Height="100" BorderBrush="#FF091B41"/>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBox Text="{Binding NewValidValue, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,5" BorderBrush="#FF091B41"/>
                    <Button Content="Добавить" Command="{Binding AddValidCommand}" Background="#FFEB075E" Foreground="White" Height="25" Margin="0,0,0,5" BorderThickness="0"/>
                    <Button Content="Удалить" Command="{Binding RemoveValidCommand}" Background="#FFC2C5DC" Height="25" BorderThickness="0"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Невалидные строки (str_invalid):" FontWeight="SemiBold" Foreground="#FF091B41" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ListBox Grid.Column="0" ItemsSource="{Binding InvalidValues}" SelectedItem="{Binding SelectedInvalidValue}" Height="100" BorderBrush="#FF091B41"/>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBox Text="{Binding NewInvalidValue, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,5" BorderBrush="#FF091B41"/>
                    <Button Content="Добавить" Command="{Binding AddInvalidCommand}" Background="#FFEB075E" Foreground="White" Height="25" Margin="0,0,0,5" BorderThickness="0"/>
                    <Button Content="Удалить" Command="{Binding RemoveInvalidCommand}" Background="#FFC2C5DC" Height="25" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>